# API Configuration
# Copy this file to .env and update the values

# Backend API URL
# For local development on a physical device: http://YOUR_COMPUTER_LAN_IP:5000/api
# For Android emulator: http://10.0.2.2:5000/api
# If you leave this as localhost, the mobile client will try to replace it with the Metro host automatically.
# For production: https://your-api-domain.com/api
# EXPO_PUBLIC_API_URL=https://coursex-77do.onrender.com/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api